import os
import sys
import json
import asyncio

async def run_auto_post(w_dir, t_key):
    # 1. config.json の読み込み
    config_path = os.path.join(w_dir, "config.json")
    if not os.path.exists(config_path):
        print(f"Error: {config_path} not found.")
        sys.exit(1)
        
    try:
        with open(config_path, "r", encoding="utf-8") as f:
            # 文字列として誤認識されるのを防ぐため、明示的に辞書型としてロード
            p = json.load(f)
            if isinstance(p, str):
                p = json.loads(p)
    except Exception as e:
        print(f"Error parsing config.json: {e}")
        sys.exit(1)

    # 2. チャンネルIDの出力とチェック
    channel_id = p.get("channel_id")
    if not channel_id:
        print("Error: 'channel_id' is missing in config.json")
        sys.exit(1)
        
    print(f"PROFILE: {p.get('profile_name', 'unknown')}")
    print(f"CHANNEL_ID: {channel_id}")

    # 3. 本来の自動投稿メイン処理（モック実行・環境検証）
    print("Initializing auto post environment...")
    print(f"Topic: {p.get('topic')}, Language: {p.get('lang')}")
    print(f"BGM File: {p.get('bgm_file')}, Target Directory: {p.get('bg_pool_dir')}")
    
    # 実際の投稿ロジックがここに続きますが、まずは読み込みを完全パスさせます
    print("Configuration loaded successfully. Proceeding to video generation...")
    
    # 必要に応じて、本来のメインロジックの呼び出しをここに記述してください
    # 例: await execute_post_logic(p)
    print("Success: Pipeline completed.")

if __name__ == "__main__":
    # 実行時のカレントディレクトリとプロファイルキーを設定
    w_dir = os.getcwd()
    t_key = "pawvana"
    
    # 非同期処理の実行
    asyncio.run(run_auto_post(w_dir, t_key))